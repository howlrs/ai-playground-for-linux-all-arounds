#!/usr/bin/env bash
set -euo pipefail

# AgentDB - CLI wrapper for multi-agent shared database (SurrealDB)
# Usage: agentdb <command> [args...]

AGENTDB_BIND="${AGENTDB_BIND:-127.0.0.1:8000}"
AGENTDB_USER="${AGENTDB_USER:-root}"
AGENTDB_PASS="${AGENTDB_PASS:-root}"
AGENTDB_NS="agents"
AGENTDB_AGENT="${AGENTDB_AGENT:-unknown}"

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

_sql() {
  local db="$1"
  surreal sql \
    --endpoint "http://${AGENTDB_BIND}" \
    --username "${AGENTDB_USER}" \
    --password "${AGENTDB_PASS}" \
    --namespace "${AGENTDB_NS}" \
    --database "${db}"
}

_sql_exec() {
  local db="$1"
  local query="$2"
  echo "${query}" | _sql "${db}"
}

# Escape string for SurrealQL string literals (prevents injection)
_escape() {
  printf '%s' "$1" | sed "s/\\\\/\\\\\\\\/g; s/'/''/g"
}

# Validate JSON using jq (if available) or basic check
_validate_json() {
  if command -v jq >/dev/null 2>&1; then
    if ! printf '%s' "$1" | jq . >/dev/null 2>&1; then
      echo "Invalid JSON: $1" >&2
      return 1
    fi
  else
    # Basic check: reject semicolons outside of string values (prevents query injection)
    if [[ "$1" =~ \;[[:space:]]*[A-Z] ]]; then
      echo "Invalid data: contains suspicious pattern" >&2
      return 1
    fi
  fi
}

# Validate --db parameter
_validate_db() {
  if [[ "$1" != "logs" && "$1" != "knowledge" ]]; then
    echo "Invalid database: $1 (must be 'logs' or 'knowledge')" >&2
    return 1
  fi
}

# Validate duration format (e.g. 1h, 7d, 30m, 10s)
_validate_duration() {
  if [[ ! "$1" =~ ^[0-9]+[smhd]$ ]]; then
    echo "Invalid duration: $1 (expected format: Ns, Nm, Nh, Nd)" >&2
    return 1
  fi
}

# Validate positive integer
_validate_int() {
  if [[ ! "$1" =~ ^[0-9]+$ ]]; then
    echo "Invalid number: $1" >&2
    return 1
  fi
}

# Validate SurrealDB record ID format (e.g. entry:abc123, event:xyz)
_validate_record_id() {
  if [[ ! "$1" =~ ^[a-zA-Z_][a-zA-Z0-9_]*:[a-zA-Z0-9_-]+$ ]]; then
    echo "Invalid record ID: $1 (expected format: table:id)" >&2
    return 1
  fi
}

_usage() {
  cat <<'USAGE'
AgentDB - CLI wrapper for multi-agent shared database

Usage: agentdb <command> [args...]

Logs DB commands:
  log <type> <data_json>           Create a log event
  search <keyword> [options]       Search log events
    --type <T>                       Filter by event type
    --agent <A>                      Filter by agent name
    --since <DURATION>               Filter by time (e.g. 1h, 7d)
    --limit <N>                      Max results (default: 20)

Knowledge DB commands:
  save <kind> <title> <body> [options]  Save a knowledge entry
    --domain <D>                     Domain classification
    --tags <t1,t2,...>               Comma-separated tags
  find <keyword> [options]              Search knowledge entries
    --kind <K>                       Filter by kind
    --agent <A>                      Filter by agent name
    --domain <D>                     Filter by domain
    --limit <N>                      Max results (default: 20)
  relate <from_id> <relation> <to_id>   Create a relation between entries

Common commands:
  query <surql> [--db logs|knowledge]   Execute raw SurrealQL (default db: logs)
  status                                Check health and show record counts
  cleanup                               Delete log events older than 14 days

Environment variables:
  AGENTDB_BIND   SurrealDB address (default: 127.0.0.1:8000)
  AGENTDB_USER   Username (default: root)
  AGENTDB_PASS   Password (default: root)
  AGENTDB_AGENT  Calling agent name (default: unknown)
USAGE
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_log() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: agentdb log <type> <data_json>" >&2
    return 1
  fi
  local type="$1"
  local data="$2"

  _validate_json "${data}" || return 1
  local e_agent; e_agent="$(_escape "${AGENTDB_AGENT}")"
  local e_type; e_type="$(_escape "${type}")"
  _sql_exec "logs" "CREATE event SET agent = '${e_agent}', type = '${e_type}', data = ${data}, created_at = time::now();"
}

cmd_search() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: agentdb search <keyword> [--type T] [--agent A] [--since DURATION] [--limit N]" >&2
    return 1
  fi
  local keyword="$1"; shift

  local filter_type="" filter_agent="" filter_since="" limit="20"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)  filter_type="$2"; shift 2 ;;
      --agent) filter_agent="$2"; shift 2 ;;
      --since) filter_since="$2"; shift 2 ;;
      --limit) limit="$2"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; return 1 ;;
    esac
  done

  _validate_int "${limit}" || return 1
  [[ -n "${filter_since}" ]] && { _validate_duration "${filter_since}" || return 1; }

  local e_keyword; e_keyword="$(_escape "${keyword}")"
  local where="WHERE string::lowercase(type) CONTAINS string::lowercase('${e_keyword}') OR string::lowercase(<string> data) CONTAINS string::lowercase('${e_keyword}')"
  [[ -n "${filter_type}" ]]  && where="${where} AND type = '$(_escape "${filter_type}")'"
  [[ -n "${filter_agent}" ]] && where="${where} AND agent = '$(_escape "${filter_agent}")'"
  [[ -n "${filter_since}" ]] && where="${where} AND created_at > time::now() - ${filter_since}"

  _sql_exec "logs" "SELECT * FROM event ${where} ORDER BY created_at DESC LIMIT ${limit};"
}

cmd_save() {
  if [[ $# -lt 3 ]]; then
    echo "Usage: agentdb save <kind> <title> <body> [--domain D] [--tags t1,t2]" >&2
    return 1
  fi
  local kind="$1" title="$2" body="$3"; shift 3

  local domain="NONE" tags="NONE"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain) domain="'$(_escape "$2")'"; shift 2 ;;
      --tags)
        # Convert comma-separated tags to SurrealQL array: ['a','b','c']
        local raw="$2"
        local tag_arr=""
        IFS=',' read -ra tag_parts <<< "${raw}"
        for t in "${tag_parts[@]}"; do
          [[ -n "${tag_arr}" ]] && tag_arr="${tag_arr},"
          tag_arr="${tag_arr}'$(_escape "${t}")'"
        done
        tags="[${tag_arr}]"
        shift 2
        ;;
      *) echo "Unknown option: $1" >&2; return 1 ;;
    esac
  done

  local e_agent; e_agent="$(_escape "${AGENTDB_AGENT}")"
  local e_kind; e_kind="$(_escape "${kind}")"
  local e_title; e_title="$(_escape "${title}")"
  local e_body; e_body="$(_escape "${body}")"
  _sql_exec "knowledge" "CREATE entry SET agent = '${e_agent}', kind = '${e_kind}', title = '${e_title}', body = '${e_body}', domain = ${domain}, tags = ${tags}, created_at = time::now(), updated_at = time::now();"
}

cmd_find() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: agentdb find <keyword> [--kind K] [--agent A] [--domain D] [--limit N]" >&2
    return 1
  fi
  local keyword="$1"; shift

  local filter_kind="" filter_agent="" filter_domain="" limit="20"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --kind)   filter_kind="$2"; shift 2 ;;
      --agent)  filter_agent="$2"; shift 2 ;;
      --domain) filter_domain="$2"; shift 2 ;;
      --limit)  limit="$2"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; return 1 ;;
    esac
  done

  _validate_int "${limit}" || return 1

  local e_keyword; e_keyword="$(_escape "${keyword}")"
  local where="WHERE string::lowercase(title) CONTAINS string::lowercase('${e_keyword}') OR string::lowercase(body) CONTAINS string::lowercase('${e_keyword}')"
  [[ -n "${filter_kind}" ]]   && where="${where} AND kind = '$(_escape "${filter_kind}")'"
  [[ -n "${filter_agent}" ]]  && where="${where} AND agent = '$(_escape "${filter_agent}")'"
  [[ -n "${filter_domain}" ]] && where="${where} AND domain = '$(_escape "${filter_domain}")'"

  _sql_exec "knowledge" "SELECT * FROM entry ${where} ORDER BY created_at DESC LIMIT ${limit};"
}

cmd_relate() {
  if [[ $# -lt 3 ]]; then
    echo "Usage: agentdb relate <from_id> <relation> <to_id>" >&2
    return 1
  fi
  local from_id="$1" relation="$2" to_id="$3"

  _validate_record_id "${from_id}" || return 1
  _validate_record_id "${to_id}" || return 1
  local e_relation; e_relation="$(_escape "${relation}")"
  _sql_exec "knowledge" "RELATE ${from_id}->relates_to->${to_id} SET relation = '${e_relation}', created_at = time::now();"
}

cmd_query() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: agentdb query <surql> [--db logs|knowledge]" >&2
    return 1
  fi
  local surql="$1"; shift

  local db="logs"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --db) db="$2"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; return 1 ;;
    esac
  done

  _validate_db "${db}" || return 1
  _sql_exec "${db}" "${surql}"
}

cmd_status() {
  echo "=== AgentDB Status ==="
  echo "Endpoint: http://${AGENTDB_BIND}"
  echo "Namespace: ${AGENTDB_NS}"
  echo "Agent: ${AGENTDB_AGENT}"
  echo ""
  if ! curl -sf "http://${AGENTDB_BIND}/health" >/dev/null 2>&1; then
    echo "SurrealDB: NOT RUNNING" >&2
    echo "Start with: bash ~/scripts/start-surreal.sh" >&2
    return 1
  fi
  echo "SurrealDB: running"
  echo ""
  echo "--- Logs DB ---"
  _sql_exec "logs" "SELECT count() AS total FROM event GROUP ALL;"
  echo ""
  echo "--- Knowledge DB ---"
  _sql_exec "knowledge" "SELECT count() AS total FROM entry GROUP ALL;"
}

cmd_cleanup() {
  echo "Cleaning up log events older than 14 days..."
  _sql_exec "logs" "DELETE FROM event WHERE created_at < time::now() - 14d;"
  echo "Done."
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

if [[ $# -lt 1 ]]; then
  _usage
  exit 1
fi

case "$1" in
  log)     shift; cmd_log "$@" ;;
  search)  shift; cmd_search "$@" ;;
  save)    shift; cmd_save "$@" ;;
  find)    shift; cmd_find "$@" ;;
  relate)  shift; cmd_relate "$@" ;;
  query)   shift; cmd_query "$@" ;;
  status)  cmd_status ;;
  cleanup) cmd_cleanup ;;
  help|-h|--help) _usage ;;
  *)
    echo "Unknown command: $1" >&2
    echo "" >&2
    _usage >&2
    exit 1
    ;;
esac
