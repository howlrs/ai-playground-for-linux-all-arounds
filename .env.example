# =============================================================================
# AI Playground - Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- AI Agents ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- GitHub ---
# GH_TOKEN=ghp_...
# GITHUB_TOKEN=ghp_...

# --- GitLab ---
# GITLAB_TOKEN=glpat-...

# --- Microsoft 365 / Teams ---
# M365_APP_ID=              # Entra ID app registration client ID
# M365_TENANT_ID=           # Azure AD tenant ID
# M365_APP_SECRET=          # Client secret (for non-interactive auth)

# --- AWS (optional - prefer mounting ~/.aws instead) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-northeast-1

# --- Google Cloud (optional - prefer mounting ~/.config/gcloud instead) ---
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Google Workspace CLI ---
# GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=
# GOOGLE_WORKSPACE_CLI_TOKEN=
